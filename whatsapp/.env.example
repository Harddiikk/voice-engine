# Copy to .env and fill in. `cp .env.example .env`
# Public URL Evolution advertises (use your VPS URL/domain in production).
SERVER_URL=http://localhost:8080

# Master API key — used as the `apikey` header for all admin + global calls.
# Generate a long random one:  openssl rand -hex 24
AUTHENTICATION_API_KEY=change-me-openssl-rand-hex-24

# Postgres credentials (used by the bundled db container + Evolution's connection URI).
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=change-me-strong-password
